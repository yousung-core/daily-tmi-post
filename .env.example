# ==========================================
# Daily TMI Post - 환경 변수
# .env.local에 복사 후 실제 값으로 교체
# ==========================================

# ------------------------------------------
# Supabase (필수)
# Supabase Dashboard > Settings > API에서 확인
# ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------
# 사이트 URL (필수)
# 프로덕션: 실제 도메인, 개발: http://localhost:3000
# ------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------
# AI 기사 다듬기 - Google Gemini (선택)
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
# ------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------
# 이메일 알림 - Resend (선택)
# 기사 승인/반려 시 신청자에게 이메일 발송
# Resend에서 발급: https://resend.com/api-keys
# ------------------------------------------
RESEND_API_KEY=re_xxxxx

# ------------------------------------------
# 카카오톡 공유 - Kakao JavaScript SDK (선택)
# Kakao Developers에서 발급: https://developers.kakao.com
# 내 애플리케이션 > 앱 키 > JavaScript 키
# ------------------------------------------
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-js-key-here

# ------------------------------------------
# 소셜 로그인 (선택)
# OAuth 설정은 각 프로바이더 + Supabase Dashboard에서 진행
# 환경 변수가 아닌 Supabase Auth 설정으로 관리됨
# - Google: Google Cloud Console > OAuth 2.0 Client ID
# - Kakao: Kakao Developers > REST API 키
# - Naver: Naver Developers > Client ID/Secret
# ------------------------------------------

# ------------------------------------------
# Google AdSense (선택 - 추후)
# AdSense 승인 후 설정
# ------------------------------------------
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxx
